APP_ENV=development
PORT=8080
DATABASE_URL=postgres://hivemind:hivemind@localhost:5432/hivemind?sslmode=disable
# Auto-run migrations on boot. Defaults to true outside production.
# Set explicitly to override (e.g. AUTO_MIGRATE=true in production).
AUTO_MIGRATE=true
JWT_PRIVATE_KEY_PATH=./certs/private.pem
JWT_PUBLIC_KEY_PATH=./certs/public.pem
DOCKER_HOST=unix:///var/run/docker.sock
# Deployment backend: "swarm" (default, real Docker Swarm) or "stub" (simulated,
# applies nothing — for local dev without Docker). On "swarm", a connection
# failure is fatal in production and falls back to the stub elsewhere.
ORCHESTRATOR=swarm
# Base64-encoded 32-byte key for AES-256-GCM encryption of secret values and
# secret-flagged env vars at rest. Leave empty in dev (values stored in clear,
# logged as a warning). REQUIRED in production.
# Generate: openssl rand -base64 32
AES_KEY=
# Initial admin account, created on first boot (F-MVP-01)
ADMIN_EMAIL=admin@hivemind.local
ADMIN_PASSWORD=changeme
# Display name of the default cluster seeded on first boot. It targets the
# ambient Docker environment (DOCKER_HOST) and is where resources without an
# explicit cluster are deployed. Defaults to "default".
DEFAULT_CLUSTER_NAME=default
# Canonical externally reachable base URL of this server (INCLUDE the scheme),
# used to render the agent install/deploy commands shown in the UI.
# Empty falls back to AGENT_PUBLIC_URL, then to the incoming request's host.
HIVEMIND_BASE_URL=http://hivemind.local
# ─── Agent mode (optional, only for mTLS agents) ──────────────────────────────
# Leave all three empty unless you connect remote clusters via the Hivemind agent.
#
# Where THIS server opens the mTLS tunnel listener (bind address). Empty = mTLS
# agent hub disabled (agents can still use token mode over HIVEMIND_BASE_URL).
AGENT_HUB_ADDR=
# The address agents are told to dial to reach this server (host:port). May
# differ from AGENT_HUB_ADDR (NAT / load-balancer / public DNS). Its host is
# automatically added to the server certificate.
#   prod:  hivemind.example.com:8443
#   local: host.docker.internal:8443
AGENT_HUB_PUBLIC_ADDR=
# Optional extra hostname for the server certificate SAN (rarely needed — the
# host of AGENT_HUB_PUBLIC_ADDR is already included).
AGENT_HUB_HOSTNAME=
# Agent image used in the generated install/compose. On a multi-node Swarm it
# must be pullable by every node — point this at a registry. Default:
# open226/hivemind-agent:latest (published multi-arch image).
AGENT_IMAGE=
