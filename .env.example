APP_ENV=development
PORT=8080
DATABASE_URL=postgres://hivemind:hivemind@localhost:5432/hivemind?sslmode=disable
# Auto-run migrations on boot. Defaults to true outside production.
# Set explicitly to override (e.g. AUTO_MIGRATE=true in production).
AUTO_MIGRATE=true
JWT_PRIVATE_KEY_PATH=./certs/private.pem
JWT_PUBLIC_KEY_PATH=./certs/public.pem
DOCKER_HOST=unix:///var/run/docker.sock
# Deployment backend: "swarm" (default, real Docker Swarm) or "stub" (simulated,
# applies nothing — for local dev without Docker). On "swarm", a connection
# failure is fatal in production and falls back to the stub elsewhere.
ORCHESTRATOR=swarm
# Base64-encoded 32-byte key for AES-256-GCM encryption of secret values and
# secret-flagged env vars at rest. Leave empty in dev (values stored in clear,
# logged as a warning). REQUIRED in production.
# Generate: openssl rand -base64 32
AES_KEY=
# Initial admin account, created on first boot (F-MVP-01)
ADMIN_EMAIL=admin@hivemind.local
ADMIN_PASSWORD=changeme
